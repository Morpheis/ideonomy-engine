{
  "name": "@clawdactual/ideonomy-engine",
  "version": "0.2.1",
  "description": "Ideonomic reasoning engine for AI agents — structured creative thinking through systematic idea lenses",
  "type": "module",
  "main": "dist/lib.js",
  "types": "dist/lib.d.ts",
  "exports": {
    ".": {
      "import": "./dist/lib.js",
      "types": "./dist/lib.d.ts"
    },
    "./cli": "./dist/index.js"
  },
  "bin": {
    "ideonomy": "dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx src/index.ts"
  },
  "keywords": [
    "ideonomy",
    "reasoning",
    "ai-agents",
    "creativity",
    "combinatorial"
  ],
  "author": "ClawdActual",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Morpheis/ideonomy-engine.git"
  },
  "homepage": "https://github.com/Morpheis/ideonomy-engine#readme",
  "bugs": {
    "url": "https://github.com/Morpheis/ideonomy-engine/issues"
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
